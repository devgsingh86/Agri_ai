{
  "name": "agri-ai-backend",
  "version": "1.0.0",
  "description": "Agri AI Backend API - Farmer Onboarding & Profile Management",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts' --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.json",
    "test:unit": "jest --config jest.config.json --testPathPattern=tests/unit",
    "test:integration": "jest --config jest.config.json --testPathPattern=tests/integration",
    "test:coverage": "jest --config jest.config.json --coverage",
    "migrate": "knex migrate:latest --knexfile src/config/database.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile src/config/database.ts",
    "seed": "knex seed:run --knexfile src/config/database.ts"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "objection": "^3.1.3",
    "pg": "^8.11.3",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "@types/yamljs": "^0.2.34",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
