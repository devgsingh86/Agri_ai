# Application
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=agriai
DB_PASSWORD=agriaipassword
DB_NAME=agri_ai_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_run_openssl_rand_-hex_64
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:8081

# Logging
LOG_LEVEL=debug
