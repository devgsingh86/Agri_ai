{
  "name": "AgriAI",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "JAVA_HOME=/opt/homebrew/opt/openjdk@17 ANDROID_HOME=/opt/homebrew/share/android-commandlinetools ANDROID_SDK_ROOT=/opt/homebrew/share/android-commandlinetools react-native run-android",
    "ios": "react-native run-ios",
    "start": "REACT_EDITOR=/usr/local/bin/code JAVA_HOME=/opt/homebrew/opt/openjdk@17 ANDROID_HOME=/opt/homebrew/share/android-commandlinetools react-native start",
